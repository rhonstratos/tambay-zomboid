# Steam credentials (optional — leave empty for stable branch)
STEAM_USER=
STEAM_PASSWORD=

# Server runtime config
SERVER_NAME=tambay_server
ADMIN_PASSWORD=change_me

# Data directory (mount this volume for persistence)
# CasaOS example: ZOMBOID_DIR=/root/mnt/nextcloud_data/Zomboid
ZOMBOID_DIR=/home/pzuser/Zomboid

# Container user (must match the Docker build arg if overridden)
PZ_USER=pzuser

# Timezone and locale
TZ=Asia/Manila
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
