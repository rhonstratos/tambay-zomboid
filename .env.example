# Steam credentials (optional — leave empty for stable branch)
STEAM_USER=
STEAM_PASSWORD=

# Set to "true" to force SteamCMD update on next container start
# FORCE_UPDATE=true

# Server runtime config
SERVER_NAME=tambay_server
ADMIN_PASSWORD=change_me

# Host path for persistent data (used by compose.yml as the mount source)
# CasaOS example: ZOMBOID_DIR=/root/mnt/nextcloud_data
# Default (relative to compose.yml): ./Zomboid
ZOMBOID_DIR=./Zomboid

# Container user (must match the Docker build arg if overridden)
PZ_USER=pzuser

# Timezone and locale
TZ=Asia/Manila
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
